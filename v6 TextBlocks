local function startMatrixLogic()
    matrixConnection = RunService.Heartbeat:Connect(function()
        local character = localPlayer.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        
        local myPos = rootPart.Position
        local currentTime = tick()
        local currentGrid = generateTextGrid(ContentBox.Text)
        local textPointsNeeded = #currentGrid
        local maxTotalBlocksAllowed = math.max(1, math.floor(_G.MatrixSettings.WaitCount))
        
        -- УМНЫЙ СКАНЕР СЕТКИ
        if currentTime - lastScanTime > 0.3 then
            lastScanTime = currentTime
            local allCurrentBlocks = {}
            for _, p in ipairs(_G.TextBlocks) do table.insert(allCurrentBlocks, p) end
            for _, p in ipairs(_G.ReserveBlocks) do table.insert(allCurrentBlocks, p) end
            
            _G.TextBlocks = {}
            _G.ReserveBlocks = {}
            
            for i = #allCurrentBlocks, 1, -1 do
                local p = allCurrentBlocks[i]
                if not p or not p.Parent or p.Anchored or (p.Position - myPos).Magnitude > _G.MatrixSettings.Distance then
                    cleanSpecificPart(p)
                    table.remove(allCurrentBlocks, i)
                end
            end
            
            if #allCurrentBlocks < maxTotalBlocksAllowed then
                local foundParts = {}
                for _, part in ipairs(workspace:GetDescendants()) do
                    if part:IsA("BasePart") and not part.Anchored and not part:IsDescendantOf(character) and not part.Parent:FindFirstChildOfClass("Humanoid") then
                        if not table.find(allCurrentBlocks, part) then
                            local distance = (part.Position - myPos).Magnitude
                            if distance <= _G.MatrixSettings.Distance then
                                table.insert(foundParts, part)
                            end
                        end
                    end
                end
                table.sort(foundParts, function(a, b)
                    return (a.Position - myPos).Magnitude < (b.Position - myPos).Magnitude
                end)
                for _, part in ipairs(foundParts) do
                    if #allCurrentBlocks >= maxTotalBlocksAllowed then break end
                    table.insert(allCurrentBlocks, part)
                end
            end
            
            while #allCurrentBlocks > maxTotalBlocksAllowed do
                local extraPart = table.remove(allCurrentBlocks)
                if extraPart then cleanSpecificPart(extraPart) end
            end
            
            for i, part in ipairs(allCurrentBlocks) do
                if #_G.TextBlocks < textPointsNeeded then
                    table.insert(_G.TextBlocks, part)
                else
                    table.insert(_G.ReserveBlocks, part)
                end
            end
        end
--4
        local lookDirection = rootPart.CFrame.LookVector
        local rightDirection = rootPart.CFrame.RightVector
        local upDirection = rootPart.CFrame.UpVector
        
        -- 1. Отрендерить Рисунок
        for index, part in ipairs(_G.TextBlocks) do
            if part and part.Parent and index <= textPointsNeeded then
                local targetOffset2D = currentGrid[index]
                if origCollisions[part] == nil then origCollisions[part] = part.CanCollide end
                pcall(function() part.CanCollide = false end)
                pcall(function()
                    if part:GetNetworkOwner() ~= localPlayer then part:SetNetworkOwner(localPlayer) end
                end)
                
                local attachment = part:FindFirstChild("MatrixAttachment") or Instance.new("Attachment", part)
                attachment.Name = "MatrixAttachment"
                
                local ap = part:FindFirstChild("MatrixAlignPos") or Instance.new("AlignPosition", part)
                if ap.Name ~= "MatrixAlignPos" then
                    ap.Name = "MatrixAlignPos"
                    ap.MaxForce = math.huge
                    ap.MaxVelocity = 250
                    ap.Mode = Enum.PositionAlignmentMode.OneAttachment
                    ap.Attachment0 = attachment
                end
                ap.Responsiveness = _G.MatrixSettings.Attraction * 5
                
                local ao = part:FindFirstChild("MatrixAlignOri") or Instance.new("AlignOrientation", part)
                if ao.Name ~= "MatrixAlignOri" then
                    ao.Name = "MatrixAlignOri"
                    ao.MaxTorque = math.huge
                    ao.Responsiveness = 25
                    ao.Mode = Enum.OrientationAlignmentMode.OneAttachment
                    ao.Attachment0 = attachment
                end
                
                -- Рассчитываем Z-глубину для надписи
                local forwardOffset = lookDirection * (_G.MatrixSettings.FaceDistance + _G.MatrixSettings.TextZOffset)
                local horizontalOffset = rightDirection * (targetOffset2D.X * _G.MatrixSettings.GridScale)
                local verticalOffset = upDirection * ((targetOffset2D.Y * _G.MatrixSettings.GridScale) + _G.MatrixSettings.TextYOffset)
                local globalTargetWorldPos = myPos + forwardOffset + horizontalOffset + verticalOffset
                
                ap.Position = globalTargetWorldPos
                ao.CFrame = rootPart.CFrame
                pcall(function()
                    part.AssemblyLinearVelocity = part.AssemblyLinearVelocity * 0.15
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end)
            end
        end
        
        -- 2. Отрендерить сетку Резерва
        for reserveIndex, part in ipairs(_G.ReserveBlocks) do
            if part and part.Parent then
                if origCollisions[part] == nil then origCollisions[part] = part.CanCollide end
                pcall(function() part.CanCollide = true end)
                pcall(function()
                    if part:GetNetworkOwner() ~= localPlayer then part:SetNetworkOwner(localPlayer) end
                end)
                
                local attachment = part:FindFirstChild("MatrixAttachment") or Instance.new("Attachment", part)
                attachment.Name = "MatrixAttachment"
                
                local ap = part:FindFirstChild("MatrixAlignPos") or Instance.new("AlignPosition", part)
                if ap.Name ~= "MatrixAlignPos" then
                    ap.Name = "MatrixAlignPos"
                    ap.MaxForce = math.huge
                    ap.MaxVelocity = 250
                    ap.Mode = Enum.PositionAlignmentMode.OneAttachment
                    ap.Attachment0 = attachment
                end
                ap.Responsiveness = _G.MatrixSettings.Attraction * 5
                
                local ao = part:FindFirstChild("MatrixAlignOri") or Instance.new("AlignOrientation", part)
                if ao.Name ~= "MatrixAlignOri" then
                    ao.Name = "MatrixAlignOri"
                    ao.MaxTorque = math.huge
                    ao.Responsiveness = 25
                    ao.Mode = Enum.OrientationAlignmentMode.OneAttachment
                    ao.Attachment0 = attachment
                end
                
                local maxCols = math.max(1, math.floor(_G.MatrixSettings.ReserveColumns))
                local maxRows = math.max(1, math.floor(_G.MatrixSettings.ReserveRowsMax))
                local spacing = _G.MatrixSettings.ReserveSpacing
                
                local colIndex = (reserveIndex - 1) % maxCols
                local rowIndex = math.floor((reserveIndex - 1) / maxCols)
                if rowIndex >= maxRows then rowIndex = maxRows - 1 end
                
                local rowWidthOffset = ((maxCols - 1) * spacing) / 2
                local xPos = (colIndex * spacing) - rowWidthOffset + _G.MatrixSettings.ReserveXOffset
                local yPos = _G.MatrixSettings.ReserveHeight + (rowIndex * spacing)
                
                -- Применяем Z-глубину для резервной очереди кубов
                local forwardOffset = lookDirection * _G.MatrixSettings.ReserveZOffset
                local horizontalOffset = rightDirection * xPos
                local verticalOffset = upDirection * yPos
                local globalTargetWorldPos = myPos + forwardOffset + horizontalOffset + verticalOffset
                
                ap.Position = globalTargetWorldPos
                ao.CFrame = rootPart.CFrame
                pcall(function()
                    local currentVelocity = part.AssemblyLinearVelocity
                    part.AssemblyLinearVelocity = currentVelocity * 0.15
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end)
            end
        end
    end)
end

local function deleteForces()
    if matrixConnection then matrixConnection:Disconnect(); matrixConnection = nil end
    for _, part in ipairs(_G.TextBlocks) do cleanPart(part) end
    for _, part in ipairs(_G.ReserveBlocks) do cleanPart(part) end
    for part, col in pairs(origCollisions) do
        if part and part.Parent then pcall(function() part.CanCollide = col end) end
    end
    _G.TextBlocks = {}
    _G.ReserveBlocks = {}
    targetedParts = {}
    origCollisions = {}
end

AnchorBtn.MouseButton1Click:Connect(function()
    local function anchorPool(pool)
        for _, part in ipairs(pool) do
            if part and part.Parent then
                pcall(function()
                    local ap = part:FindFirstChild("MatrixAlignPos")
                    local ao = part:FindFirstChild("MatrixAlignOri")
                    local att = part:FindFirstChild("MatrixAttachment")
                    if ap then ap:Destroy() end
                    if ao then ao:Destroy() end
                    if att then att:Destroy() end
                    part.Anchored = true
                    totalAnchoredHistory[part] = origCollisions[part] or true
                end)
            end
        end
    end
    anchorPool(_G.TextBlocks)
    anchorPool(_G.ReserveBlocks)
    _G.TextBlocks = {}
    _G.ReserveBlocks = {}
    targetedParts = {}
    origCollisions = {}
end)

UnanchorBtn.MouseButton1Click:Connect(function()
    local character = localPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    local myPos = rootPart.Position
    for part, savedCollision in pairs(totalAnchoredHistory) do
        if part and part.Parent then
            local distance = (part.Position - myPos).Magnitude
            if distance <= _G.MatrixSettings.Distance then
                pcall(function()
                    part.Anchored = false
                    part.CanCollide = savedCollision
                    totalAnchoredHistory[part] = nil
                end)
            end
        end
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
