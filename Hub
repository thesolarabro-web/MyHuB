    else
        GamesTabBtn.TextColor3 = Color3.fromRGB(130, 130, 150)
        GamesTabStroke.Color = Color3.fromRGB(60, 45, 80)
        OtherTabBtn.TextColor3 = Color3.fromRGB(157, 78, 221)
        OtherTabStroke.Color = Color3.fromRGB(157, 78, 221)
    end
end
