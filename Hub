    if showGames then
        GamesTabBtn.TextColor3 = Color3.fromRGB(157, 78, 221)
        GamesTabStroke.Color = Color3.fromRGB(157, 78, 221)
        OtherTabBtn.TextColor3 = Color3.fromRGB(130, 130, 150)
