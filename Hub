local allButtons = {}

local function CreateHubButton(text, parentPage, callback)
    local Btn = Instance.new("TextButton", parentPage)
    Btn.Size = UDim2.new(1, -5, 0, 36)
    Btn.BackgroundColor3 = Color3.fromRGB(25, 22, 38)
    Btn.Text = "  " .. text
    Btn.TextColor3 = Color3.fromRGB(157, 78, 221)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 11
    Btn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
    local BtnStroke = Instance.new("UIStroke", Btn)
    BtnStroke.Color = Color3.fromRGB(60, 45, 80)
    
    Btn.MouseEnter:Connect(function() Btn.BackgroundColor3 = Color3.fromRGB(35, 30, 55) end)
    Btn.MouseLeave:Connect(function() Btn.BackgroundColor3 = Color3.fromRGB(25, 22, 38) end)
    Btn.MouseButton1Click:Connect(callback)
    
    -- Регистрируем абсолютно все кнопки хаба для глобального поиска
    table.insert(allButtons, {Instance = Btn, Name = text:lower(), Page = parentPage})
    return Btn
end

