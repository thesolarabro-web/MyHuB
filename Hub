-- КАСТOМНЫЙ ДРАГ ШАПКИ С ПОДСТРОЙКОЙ СТИЛЯ ОБВОДКИ
local dragToggle = nil
local dragStart = nil
local startPos = nil
Header.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not UserInputService:GetFocusedTextBox() then
        if input.Position.X < Header.AbsolutePosition.X + Header.AbsoluteSize.X - 100 then
            dragToggle = true
            dragStart = input.Position
            startPos = MainFrame.Position
            HeaderStroke.Color = Color3.fromRGB(157, 78, 221) -- Подсвечиваем контур шапки при таскании
        end
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragToggle = false
        HeaderStroke.Color = Color3.fromRGB(60, 45, 80) -- Возвращаем дефолтный контур
    end
end)

-- РЕЖИМ ИЗМЕНЕНИЯ РАЗМЕРА
local ResizeTrigger = Instance.new("Frame", Header)
ResizeTrigger.Size = UDim2.new(0, 30, 0, 30)
ResizeTrigger.Position = UDim2.new(1, -35, 0, 4)
ResizeTrigger.BackgroundTransparency = 1
ResizeTrigger.ZIndex = 15

local resizing = false
local resizeStartPos = Vector2.new()
local startSize = Vector2.new()
local startFramePos = Vector2.new()

ResizeTrigger.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        resizing = true
        resizeStartPos = input.Position
        startSize = Vector2.new(MainFrame.AbsoluteSize.X, MainFrame.AbsoluteSize.Y)
        startFramePos = Vector2.new(MainFrame.AbsolutePosition.X, MainFrame.AbsolutePosition.Y)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - resizeStartPos
        local newWidth = math.max(340, startSize.X + delta.X)
        local newHeight = math.max(180, startSize.Y - delta.Y)
        
        if newWidth >= 460 then
            GamesGrid.CellSize = UDim2.new(0.5, -5, 0, 36)
            OtherGrid.CellSize = UDim2.new(0.5, -5, 0, 36)
        else
            GamesGrid.CellSize = UDim2.new(1, -5, 0, 36)
            OtherGrid.CellSize = UDim2.new(1, -5, 0, 36)
        end
        
        MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
        MainFrame.Position = UDim2.new(0, startFramePos.X, 0, startFramePos.Y + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        resizing = false
    end
end)
