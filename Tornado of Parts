local RunService = game:GetService("RunService")
local isTornadoActive = false
local tornadoConnection = nil
local activeParts = {}
local lastScanTime = 0

local function updateCameraMode()
    pcall(function()
        if isTornadoActive and settingsValues.CameraFixActive then
            localPlayer.DevCameraOcclusionMode = Enum.DevCameraOcclusionMode.Invisicam
        else
            localPlayer.DevCameraOcclusionMode = Enum.DevCameraOcclusionMode.Zoom
        end
    end)
end

local function cleanPart(part)
    if part then
        local lv = part:FindFirstChild("TornadoForce")
        local att = part:FindFirstChild("TornadoAttachment")
        if lv then pcall(function() lv:Destroy() end) end
        if att then pcall(function() att:Destroy() end) end
    end
end

local function startTornado()
    updateCameraMode()
    tornadoConnection = RunService.Heartbeat:Connect(function()
        local character = localPlayer.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        local myPos = rootPart.Position
        local currentTime = tick()
        if currentTime - lastScanTime > settingsValues.ScanDelay then
            lastScanTime = currentTime
            activeParts = {}
            for _, part in ipairs(workspace:GetDescendants()) do
                if part:IsA("BasePart") and not part.Anchored and not part:IsDescendantOf(character) then
                    local distance = (part.Position - myPos).Magnitude
                    if distance <= settingsValues.Distance then
                        table.insert(activeParts, part)
                    else
                        cleanPart(part)
                    end
                end
            end
        end
        for i, part in ipairs(activeParts) do
            if part and part.Parent then
                local attachment = part:FindFirstChild("TornadoAttachment")
                if not attachment then
                    pcall(function()
                        attachment = Instance.new("Attachment")
                        attachment.Name = "TornadoAttachment"
                        attachment.Parent = part
                    end)
                end
                local lv = part:FindFirstChild("TornadoForce")
                if not lv and attachment then
                    pcall(function()
                        lv = Instance.new("LinearVelocity")
                        lv.Name = "TornadoForce"
                        lv.MaxForce = 9e6
                        lv.Attachment0 = attachment
                        lv.RelativeTo = Enum.ActuatorRelativeTo.World
                        lv.Parent = part
                    end)
                end
                if lv then
                    local angle = (currentTime * settingsValues.Speed) + (i * 0.5)
                    local offsetX = math.sin(angle) * settingsValues.Radius
                    local offsetZ = math.cos(angle) * settingsValues.Radius
                    local layerOffset = (i % 10) * settingsValues.LayerSpread
                    local waveEffect = math.sin(currentTime * 2 + i) * (settingsValues.Lift / 2)
                    local offsetY = settingsValues.TornadoHeight + layerOffset + waveEffect
                    local targetPosition = myPos + Vector3.new(offsetX, offsetY, offsetZ)
                    pcall(function()
                        lv.VectorVelocity = (targetPosition - part.Position) * settingsValues.Attraction
                    end)
                end
            end
        end
    end)
end

local function stopTornado()
    updateCameraMode()
    if tornadoConnection then 
        tornadoConnection:Disconnect()
        tornadoConnection = nil 
    end
    for _, part in ipairs(activeParts) do
        cleanPart(part)
    end
    activeParts = {}
end

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
    if gameProcessedEvent then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

ToggleBtn.MouseButton1Click:Connect(function()
    isTornadoActive = not isTornadoActive
    if isTornadoActive then
        ToggleBtn.Text = "ВЫКЛЮЧИТЬ ТОРНАДО"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 120)
        startTornado()
    else
        ToggleBtn.Text = "ВКЛЮЧИТЬ ТОРНАДО"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 75)
        stopTornado()
    end
end)

