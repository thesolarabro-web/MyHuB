local function createInputRow(label, defaultVal, pos, parent)
    local frame = Instance.new("Frame") frame.Size = UDim2.new(1, 0, 0, 30) frame.Position = pos frame.BackgroundTransparency = 1 frame.Parent = parent
    local lbl = Instance.new("TextLabel") lbl.Text = label lbl.Size = UDim2.new(0.6, 0, 1, 0) lbl.TextColor3 = Theme.TextGlow lbl.BackgroundTransparency = 1 lbl.Font = Theme.FontRegular lbl.TextSize = 12 lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.Parent = frame
    local box = Instance.new("TextBox") box.Text = tostring(defaultVal) box.Size = UDim2.new(0.4, 0, 1, -6) box.Position = UDim2.new(0.6, 0, 0, 3) box.BackgroundColor3 = Theme.InputBg box.TextColor3 = Theme.TextLight box.BorderSizePixel = 0 box.Font = Theme.FontBold box.TextSize = 12 box.Parent = frame
    local bCorner = Instance.new("UICorner") bCorner.CornerRadius = UDim.new(0, 4) bCorner.Parent = box
    addNeonStroke(box, Theme.NeonGlow, 1)
    return box
end
--8
local function updateMethodVisuals()
    BtnTp.TextColor3 = Config.method == "Tp" and Theme.NeonActive or Theme.TextLight
    BtnFly.TextColor3 = Config.method == "Fly" and Theme.NeonActive or Theme.TextLight
    BtnFlyTp.TextColor3 = Config.method == "Fly tp" and Theme.NeonActive or Theme.TextLight
    
    local dChildren = DynamicSettings:GetChildren()
    for _, c in ipairs(dChildren) do
        TweenService:Create(c, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.new(1, 0, 0, 0)}):Play()
    end
    task.wait(0.15)
    DynamicSettings:ClearAllChildren()

    if Config.method == "Fly" then
        local speedBox = createInputRow(Lang[Lang.current].speed, Config.flySpeed, UDim2.new(0, 0, 0, 5), DynamicSettings)
        speedBox:GetPropertyChangedSignal("Text"):Connect(function() Config.flySpeed = tonumber(speedBox.Text) or Config.flySpeed end)
    elseif Config.method == "Fly tp" then
        local rangeBox = createInputRow(Lang[Lang.current].range, Config.flyTpRange, UDim2.new(0, 0, 0, 5), DynamicSettings)
        local intervalBox = createInputRow(Lang[Lang.current].freq_fly, Config.flyTpInterval, UDim2.new(0, 0, 0, 35), DynamicSettings)
        rangeBox:GetPropertyChangedSignal("Text"):Connect(function() Config.flyTpRange = tonumber(rangeBox.Text) or Config.flyTpRange end)
        intervalBox:GetPropertyChangedSignal("Text"):Connect(function() Config.flyTpInterval = tonumber(intervalBox.Text) or Config.flyTpInterval end)
    end
end

BtnTp.MouseButton1Click:Connect(function() Config.method = "Tp" updateMethodVisuals() end)
BtnFly.MouseButton1Click:Connect(function() Config.method = "Fly" updateMethodVisuals() end)
BtnFlyTp.MouseButton1Click:Connect(function() Config.method = "Fly tp" updateMethodVisuals() end)

