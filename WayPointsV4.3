UserInputService.InputChanged:Connect(function(input)
    if draggingFrame and input.UserInputType == Enum.UserInputType.MouseMovement then
        local scrollPos = PointsScroll.AbsolutePosition
        draggingFrame.Position = UDim2.new(0, input.Position.X - scrollPos.X - (draggingFrame.AbsoluteSize.X / 2), 0, input.Position.Y - scrollPos.Y - 15)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if draggingFrame and (input == activeGripInput or input.UserInputType == Enum.UserInputType.MouseButton1) then
        local frames = {}
        for _, child in pairs(PointsScroll:GetChildren()) do
            if child:IsA("Frame") and child ~= draggingFrame then table.insert(frames, child) end
        end
        table.sort(frames, function(a, b) return a.AbsolutePosition.Y < b.AbsolutePosition.Y end)
        local mousePos = UserInputService:GetMouseLocation()
        local insertIdx = #frames + 1
        for i, f in ipairs(frames) do
            if mousePos.Y < f.AbsolutePosition.Y + (f.AbsoluteSize.Y / 2) then insertIdx = i break end
        end
        local currentIdx = table.find(PointsScroll:GetChildren(), draggingFrame)
        if currentIdx then
            local item = table.remove(pointsList, currentIdx)
            if insertIdx > currentIdx then insertIdx = insertIdx - 1 end
            table.insert(pointsList, math.clamp(insertIdx, 1, #pointsList + 1), item)
        end
        draggingFrame.ZIndex = 1
        draggingFrame = nil
        activeGripInput = nil
        UIGridLayout.Enabled = true
        renderPoints()
    end
end)

task.spawn(function()
    while true do
        task.wait(0.01)
        if autoTpEnabled and #pointsList > 0 then
            for _, pData in ipairs(pointsList) do
                if autoTpEnabled and pData.autoTp then
                    local char = LocalPlayer.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    if root then
                        if Config.method == "Tp" then
                            root.CFrame = pData.cframe
                        elseif Config.method == "Fly" then
                            local dist = (root.Position - pData.cframe.Position).Magnitude
                            lerpMove(pData.cframe, dist / math.max(1, Config.flySpeed))
                        elseif Config.method == "Fly tp" then
                            stepMove(pData.cframe, Config.flyTpRange, Config.flyTpInterval)
                        end
                    end
                    if autoTpInterval > 0 and autoTpEnabled then task.wait(autoTpInterval) end
                end
            end
        end
    end
end)
