local function updateGridLayout()
    local currentWidth = OutlineFrame.AbsoluteSize.X
    local columns = 1
    if currentWidth >= 700 then columns = 4
    elseif currentWidth >= 520 then columns = 3
    elseif currentWidth >= 340 then columns = 2 end
    local paddingTotal = UIGridLayout.CellPadding.X.Offset * (columns - 1)
    local scrollWidth = PointsScroll.AbsoluteSize.X
    if scrollWidth == 0 then scrollWidth = currentWidth - 20 end
    local cellWidth = (scrollWidth - paddingTotal) / columns
    UIGridLayout.CellSize = UDim2.new(0, cellWidth, 0, 65)
    PointsScroll.CanvasSize = UDim2.new(0, 0, 0, UIGridLayout.AbsoluteContentSize.Y)
end

local function getCurrentCFrame()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return LocalPlayer.Character.HumanoidRootPart.CFrame
    end
    return CFrame.new(0, 15, 0)
end

local function lerpMove(targetCF, duration)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local startCF = root.CFrame
    local elapsed = 0
    while elapsed < duration and autoTpEnabled do
        local dt = RunService.Heartbeat:Wait()
        elapsed = elapsed + dt
        root.CFrame = startCF:Lerp(targetCF, math.min(1, elapsed / duration))
    end
    if autoTpEnabled then root.CFrame = targetCF end
end

local function stepMove(targetCF, range, interval)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    while (root.Position - targetCF.Position).Magnitude > range and autoTpEnabled do
        local dir = (targetCF.Position - root.Position).Unit
        root.CFrame = CFrame.new(root.Position + (dir * range), targetCF.Position)
        task.wait(interval)
    end
    if autoTpEnabled then root.CFrame = targetCF end
end
