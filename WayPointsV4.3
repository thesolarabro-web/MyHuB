            pcall(function() makefolder("WaypointsV4MyHuB") end)
        end
        local fName = (FileNameBox.Text ~= "") and FileNameBox.Text or "waypoints"
        writefile("WaypointsV4MyHuB/" .. fName .. ".json", HttpService:JSONEncode(rawTable))
        SaveFileBtn.Text = (currentLanguage == "ENG") and "SAVED!" or "СОХРАНЕНО!"
        task.wait(0.5)
        updateLocalization()
    end
end)

LoadFileBtn.MouseButton1Click:Connect(function()
    local fName = (FileNameBox.Text ~= "") and FileNameBox.Text or "waypoints"
    local fullPath = "WaypointsV4MyHuB/" .. fName .. ".json"
    if pcall(function() return readfile end) and isfile(fullPath) then
        local status, data = pcall(function() return HttpService:JSONDecode(readfile(fullPath)) end)
        if status and data then
            for _, node in ipairs(rowContainer) do
                if node.FrameRef then node.FrameRef:Destroy() end
            end
            rowContainer = {}
            for _, rawNode in ipairs(data) do
                local p = rawNode.Pos
                if p and #p == 3 then
                    createWaypointRow(rawNode.Name, Vector3.new(p, p, p), rawNode.AutoInclude)
                end
            end
            LoadFileBtn.Text = (currentLanguage == "ENG") and "LOADED!" or "ЗАГРУЖЕНО!"
        end
        task.wait(0.5)
        updateLocalization()
    end
end)

task.spawn(function()
