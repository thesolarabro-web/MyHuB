local function addNeonStroke(parent, color, thickness)
    local stroke = parent:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke")
    stroke.Color = color
    stroke.Thickness = thickness or 1.2
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.LineJoinMode = Enum.LineJoinMode.Round
    stroke.Transparency = 0.15
    stroke.Parent = parent
    return stroke
end

local function createNeonButton(name, text, pos, size, parent, bg, strokeColor)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Text = text
    btn.Position = pos
    btn.Size = size
    btn.BackgroundColor3 = bg or Theme.ButtonBg
    btn.TextColor3 = Theme.TextLight
    btn.Font = Theme.FontBold
    btn.TextSize = Theme.TextSize
    btn.BorderSizePixel = 0
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = btn
    addNeonStroke(btn, strokeColor or Theme.NeonGlow, 1)
    btn.Parent = parent
    return btn
end

