    local methods = {"TP", "FLY", "TPFLY"}
    MethodBtn.MouseButton1Click:Connect(function()
        local cur = table.find(methods, _G.WaypointsSettings.Method) or 1
        local nextIdx = (cur % #methods) + 1
        _G.WaypointsSettings.Method = methods[nextIdx]
        MethodBtn.Text = _G.WaypointsSettings.Method
    end)

    local function navigateCharacter(targetPos)
        local char = localPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local method = _G.WaypointsSettings.Method
        if method == "TP" then
            root.CFrame = CFrame.new(targetPos)
        elseif method == "FLY" then
            _G.WaypointsSettings.IsMoving = true
            local speed = _G.WaypointsSettings.FlySpeed or 50
            while (root.Position - targetPos).Magnitude > 2 and _G.WaypointsSettings.IsMoving and _G.WaypointsSettings.AutoActive do
                local direction = (targetPos - root.Position).Unit
                root.AssemblyLinearVelocity = direction * speed
                RunService.Heartbeat:Wait()
            end
            root.AssemblyLinearVelocity = Vector3.new(0,0,0)
            if _G.WaypointsSettings.AutoActive then root.CFrame = CFrame.new(targetPos) end
            _G.WaypointsSettings.IsMoving = false
        elseif method == "TPFLY" then
            _G.WaypointsSettings.IsMoving = true
            local maxStep = _G.WaypointsSettings.TpFlyDist or 10
            local stepDelay = _G.WaypointsSettings.TpFlyDelay or 0.05
            while (root.Position - targetPos).Magnitude > 0.5 and _G.WaypointsSettings.IsMoving and _G.WaypointsSettings.AutoActive do
                local remaining = targetPos - root.Position
                local currentStep = remaining.Unit * math.min(maxStep, remaining.Magnitude)
                root.CFrame = root.CFrame + currentStep
                root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                task.wait(stepDelay)
            end
            if _G.WaypointsSettings.AutoActive then root.CFrame = CFrame.new(targetPos) end
            _G.WaypointsSettings.IsMoving = false
        end
    end

