local function createSlider(text, settingName, min, max, parent)
    local f, lbl = createSettingsRow(text, parent)
    local box = Instance.new("TextBox", f)
    box.Size = UDim2.new(0.3, 0, 0.7, 0)
    box.Position = UDim2.new(0.66, 0, 0.15, 0)
    box.BackgroundColor3 = Color3.fromRGB(25, 22, 38)
    box.Text = tostring(_G.WaypointsSettings[settingName])
    box.TextColor3 = Color3.fromRGB(157, 78, 221)
    box.Font = Enum.Font.GothamBold
    box.TextSize = 9
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
    box.FocusLost:Connect(function()
        local num = tonumber(box.Text)
        if num then
            _G.WaypointsSettings[settingName] = math.clamp(num, min, max)
        else
            box.Text = tostring(_G.WaypointsSettings[settingName])
        end
    end)
    return lbl, box
end

