local isBinding = false

local function updateLocalization()
    local p = Lang.current
    TpMenuBtn.Text = Lang[p].tp
    IntervalLabel.Text = Lang[p].freq
    ConfigInput.PlaceholderText = Lang[p].placeholder
    LoadBtn.Text = Lang[p].load
    SaveBtn.Text = Lang[p].export
    LangBtn.Text = Lang[p].lang
    ConfigHeader.Text = Lang[p].cfg_header
    MethodHeader.Text = Lang[p].method_header
    BindBtn.Text = isBinding and "..." or (p == "RU" and "Скрыть: " or "Hide: ") .. currentBind.Name
    AutoTpBtn.Text = autoTpEnabled and Lang[p].auto_on or Lang[p].auto_off
    updateMethodVisuals()
    renderPoints()
end

LangBtn.MouseButton1Click:Connect(function()
    Lang.current = Lang.current == "RU" and "EN" or "RU"
    updateLocalization()
end)

BindBtn.MouseButton1Click:Connect(function() isBinding = true BindBtn.Text = "..." end)

UserInputService.InputBegan:Connect(function(input, processed)
    if isBinding and input.UserInputType == Enum.UserInputType.Keyboard then
        currentBind = input.KeyCode
        isBinding = false
        updateLocalization()
        return
    end
    if not processed and input.KeyCode == currentBind then
        OutlineFrame.Visible = not OutlineFrame.Visible
    end
end)
