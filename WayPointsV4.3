CollapseBtn.MouseButton1Click:Connect(function()
    collapsed = not collapsed
    CollapseBtn.Text = collapsed and "▼" or "▲"
    
    local targetWidth = collapsed and 76 or savedExpandedWidth
    local targetHeight = collapsed and 40 or savedExpandedHeight
    local targetContentHeight = collapsed and 0 or (savedExpandedHeight - 40)
    
    -- Смещение позиции по X влево при раскрытии и вправо при сжатии, чтобы правый край стоял на месте
    local deltaWidth = savedExpandedWidth - 76
    local currentOffsetX = OutlineFrame.Position.X.Offset
    local targetOffsetX = collapsed and (currentOffsetX + deltaWidth) or (currentOffsetX - deltaWidth)
    
    TweenService:Create(OutlineFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
        Size = UDim2.new(OutlineFrame.Size.X.Scale, targetWidth, OutlineFrame.Size.Y.Scale, targetHeight),
        Position = UDim2.new(OutlineFrame.Position.X.Scale, targetOffsetX, OutlineFrame.Position.Y.Scale, OutlineFrame.Position.Y.Offset)
    }):Play()
    
    TweenService:Create(ContentFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {Size = UDim2.new(1, 0, 0, targetContentHeight)}):Play()
    TweenService:Create(TpMenuBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = collapsed and UDim2.new(0,0,0,0) or UDim2.new(0,100,0,30), TextTransparency = collapsed and 1 or 0}):Play()
    TweenService:Create(SettingsMenuBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = collapsed and UDim2.new(0,0,0,0) or UDim2.new(0,35,0,30), TextTransparency = collapsed and 1 or 0}):Play()
    
    if collapsed then
        CollapseBtn.Position = UDim2.new(0, 5, 0, 5)
        CloseUiBtn.Position = UDim2.new(0, 40, 0, 5)
    else
        CollapseBtn.Position = UDim2.new(1, -75, 0, 5)
        CloseUiBtn.Position = UDim2.new(1, -35, 0, 5)
    end
end)

