local function createToggleSetting(text, settingName, parentPage)
    local ToggleFrame = Instance.new("Frame", parentPage)
    ToggleFrame.Size = UDim2.new(1, -6, 0, 24)
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(22, 18, 32)
    Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 5)
    local Label = Instance.new("TextLabel", ToggleFrame)
    Label.Size = UDim2.new(0.6, 0, 1, 0)
    Label.Position = UDim2.new(0.04, 0, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Color3.fromRGB(180, 180, 190)
    Label.TextSize = 9
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Font = Enum.Font.GothamSemibold
    local TglBtn = Instance.new("TextButton", ToggleFrame)
    TglBtn.Size = UDim2.new(0.32, 0, 0.75, 0)
    TglBtn.Position = UDim2.new(0.64, 0, 0.125, 0)
    TglBtn.Font = Enum.Font.GothamBold
    TglBtn.TextSize = 9
    Instance.new("UICorner", TglBtn).CornerRadius = UDim.new(0, 4)
    
    local function updateVisual()
        local active = _G.MatrixSettings[settingName]
        local isEng = (_G.MatrixSettings.Language == "ENG")
        TglBtn.Text = active and (isEng and "ON" or "ВКЛ") or (isEng and "OFF" or "ВЫКЛ")
        TglBtn.BackgroundColor3 = active and Color3.fromRGB(0, 140, 255) or Color3.fromRGB(40, 40, 50)
        TglBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
    updateVisual()
    TglBtn.MouseButton1Click:Connect(function()
        _G.MatrixSettings[settingName] = not _G.MatrixSettings[settingName]
        updateVisual()
        saveMatrixConfig()
    end)
    return Label, TglBtn
end

