                local verticalOffset = upDirection * yPos
                ap.Position = myPos + forwardOffset + horizontalOffset + verticalOffset
                ao.CFrame = rootPart.CFrame
                
                pcall(function()
                    part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                end)
            end
        end
    end)
