local function generateTextGrid(text)
    local combinedGrid = {}
    text = string.upper(text)
    local lines = {}
    for chunk in string.gmatch(text, "[^_]+") do table.insert(lines, chunk) end
    if #lines == 0 then table.insert(lines, "") end
    
    local lineSpacing = _G.MatrixSettings.LineSpacing or 6
    local totalLines = #lines
    local density = math.max(1, math.floor(_G.MatrixSettings.BlockDensity or 1))
    
    for lineIndex, lineText in ipairs(lines) do
        local yLineOffset = ((totalLines - 1) / 2 - (lineIndex - 1)) * lineSpacing
        local rawPoints = {}
        
        if lineText == "=)" then
            rawPoints = {
                Vector2.new(-2,4), Vector2.new(-2,3), Vector2.new(2,4), Vector2.new(2,3),
                Vector2.new(-3,1), Vector2.new(3,1), Vector2.new(-2,0), Vector2.new(2,0), 
                Vector2.new(-1,-1), Vector2.new(0,-1), Vector2.new(1,-1)
            }
        elseif lineText == "<3" then
            rawPoints = {
                Vector2.new(-2,4), Vector2.new(-1,4), Vector2.new(1,4), Vector2.new(2,4),
                Vector2.new(-3,3), Vector2.new(0,3), Vector2.new(3,3), 
                Vector2.new(-3,2), Vector2.new(3,2), 
                Vector2.new(-2,1), Vector2.new(2,1), 
                Vector2.new(-1,0), Vector2.new(1,0), 
                Vector2.new(0,-1)
            }
        else
            local currentLetterOffset = 0
            local lineTotalWidth = lineText:len() * 4.5
            local startX = -lineTotalWidth / 2
            for i = 1, #lineText do
                local char = lineText:sub(i, i)
                local matrix = Font3x5[char] or Font3x5[" "]
                for _, point in ipairs(matrix) do
                    table.insert(rawPoints, Vector2.new(startX + currentLetterOffset + point.X, point.Y))
                end
                currentLetterOffset = currentLetterOffset + ((char == "W") and 5.5 or 4.5)
            end
        end
        
        for _, pt in ipairs(rawPoints) do
            if density > 1 then
                for subX = 0, density - 1 do
                    for subY = 0, density - 1 do
                        table.insert(combinedGrid, Vector2.new(pt.X + (subX / density), pt.Y + (subY / density) + yLineOffset))
                    end
                end
            else
                table.insert(combinedGrid, Vector2.new(pt.X, pt.Y + yLineOffset))
            end
        end
    end
    
    if _G.MatrixSettings.MirrorActive then
        local mirroredGrid = {}
        for i = #combinedGrid, 1, -1 do
            local originalPoint = combinedGrid[i]
            table.insert(mirroredGrid, Vector2.new(-originalPoint.X, originalPoint.Y))
        end
        return mirroredGrid
    end
    return combinedGrid
end

local function cleanPart(part)
    if part then
        if origCollisions[part] ~= nil then pcall(function() part.CanCollide = origCollisions[part] end) origCollisions[part] = nil end
        local ap = part:FindFirstChild("MatrixAlignPos")
        local ao = part:FindFirstChild("MatrixAlignOri")
        local att = part:FindFirstChild("MatrixAttachment")
        if ap then pcall(function() ap:Destroy() end) end
        if ao then pcall(function() ao:Destroy() end) end
        if att then pcall(function() att:Destroy() end) end
    end
end

