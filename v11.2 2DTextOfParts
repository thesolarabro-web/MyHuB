local function saveMatrixConfig()
    if pcall(function() return writefile end) then
        if pcall(function() return makefolder end) then pcall(function() makefolder("WaypointsV4MyHuB") end) end
        writefile("WaypointsV4MyHuB/MatrixSettings.json", HttpService:JSONEncode(_G.MatrixSettings))
    end
end

if pcall(function() return readfile end) and isfile("WaypointsV4MyHuB/MatrixSettings.json") then
    local status, data = pcall(function() return HttpService:JSONDecode(readfile("WaypointsV4MyHuB/MatrixSettings.json")) end)
    if status and data then
        for key, value in pairs(data) do _G.MatrixSettings[key] = value end
    end
end

local function createSlider(text, settingName, parentPage)
    local SliderFrame = Instance.new("Frame", parentPage)
    SliderFrame.Size = UDim2.new(1, -6, 0, 22)
    SliderFrame.BackgroundColor3 = Color3.fromRGB(22, 18, 32)
    Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 5)
    local Label = Instance.new("TextLabel", SliderFrame)
    Label.Size = UDim2.new(0.65, 0, 1, 0)
    Label.Position = UDim2.new(0.04, 0, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Color3.fromRGB(180, 180, 190)
    Label.TextSize = 9
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Font = Enum.Font.GothamSemibold
    local Box = Instance.new("TextBox", SliderFrame)
    Box.Size = UDim2.new(0.28, 0, 0.75, 0)
    Box.Position = UDim2.new(0.68, 0, 0.125, 0)
    Box.BackgroundColor3 = Color3.fromRGB(25, 22, 38)
    Box.Text = tostring(_G.MatrixSettings[settingName])
    Box.TextColor3 = Color3.fromRGB(157, 78, 221)
    Box.TextSize = 9
    Box.Font = Enum.Font.GothamBold
    Instance.new("UICorner", Box).CornerRadius = UDim.new(0, 4)
    
    -- ИСПРАВЛЕНО: Отключена очистка текста при фокусе, старое число сохраняется для редактирования
    Box.ClearTextOnFocus = false
    
    Box.FocusLost:Connect(function()
        local num = tonumber(Box.Text)
        if num then _G.MatrixSettings[settingName] = num; saveMatrixConfig() else Box.Text = tostring(_G.MatrixSettings[settingName]) end
    end)
    return Label, Box
end
